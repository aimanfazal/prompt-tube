# Copy this file to `.env` and fill in your own values.
# .env is already gitignored so your key never gets committed.

# TODO (you): add your Groq API key here.
# Get one for free (no credit card) at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the model used for generation.
# llama-3.3-70b-versatile is a good default; llama-3.1-8b-instant is faster
# and has a higher free-tier request limit if you want to try it.
GROQ_MODEL=llama-3.3-70b-versatile

# Allowed origin for the frontend (CORS). Defaults to the Next.js dev server.
FRONTEND_ORIGIN=http://localhost:3000
